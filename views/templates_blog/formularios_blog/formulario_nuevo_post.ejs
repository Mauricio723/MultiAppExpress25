<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog - Formulario post</title>

    <link rel="stylesheet" href="/estilos_css/bootstrap.min.css">
    <link rel="stylesheet" href="/estilos_css/colores_const.css">
    <link rel="stylesheet" href="/estilos_css/estilos_blog.css">

    <script>

    </script>
</head>

<body>
    <header class="bg_grey text_white">
        <div class="mx-2 my-2 px-2 py-2">
            <h2>Blog SurCode25 - Formulario para agregar nuevo post</h2>
        </div>
    </header>

    <div id="div_datos_session"></div>

    <main>
        <section>
            <div class="bg_beige mx-2 my-2 px-2 py-2">
                <h3 class="text-center">Formulario de ingreso de Posteos</h3>

                <div class="mx-2 my-2">

                    <!-- formulario para enviar con FormData -->
                    <form id="id_form_post_prueba" class="mx-2 my-2 px-2 py-2">
                        <div class="bg_midnightblue text_seashell mx-1 my-1 px-1 py-1">

                            <div class="mx-2 my-2 px-1 py-1 bg_grey text_azure">
                                <div class="mb-3 ms-1 me-1">
                                    <label for="titulo" class="form-label">Título del post</label>
                                    <input type="text" class="form-control" id="titulo" name="titulo"
                                        placeholder="Ingresar el título dle post" required mingthlenth="3"
                                        maxlength="50" autofocus>
                                </div>
                            </div>

                            <div class="mx-2 my-2 px-1 py-1 bg_grey text_azure">
                                <div class="mb-3 ms-1 me-1">
                                    <label for="contenido" class="form-label">Contenido del post</label>
                                    <textarea class="form-control" id="contenido" rows="3" name="contenido" required
                                        minlength="10" maxlength="500">
                                    </textarea>
                                </div>
                            </div>

                            <div class="mx-2 my-2 px-1 py-1 bg_grey text_azure" id="div_seleccion_imagen">
                                <div class="mb-3 ms-1 me-1">
                                    <label for="imagen_url" class="form-label">URL de la imagen</label>
                                    <input type="text" class="form-control" name="imagen_url" value="sin_imagen"
                                        readonly>
                                </div>
                                <div class="d-grid d-md-flex justify-content-md-end">
                                    <span class="bg_green text_white me-2 px-2 py-1" style="cursor: pointer;"
                                        onclick="mostrarControlesImagen(true)">
                                        Si necesita agregar una imagen, presionar aquí
                                    </span>
                                </div>

                                <!--
                                <div class="mb-3 ms-1 me-1">
                                    <label for="imagen_post" class="form-label">URL de la imagen</label>                                    
                                    <input type="file" class="form-control" name="imagen_post" required>
                                </div>
                                -->
                            </div>

                            <div class="mx-2 my-2 px-1 py-1 bg_grey text_azure" id="div_input_autor">
                            </div>

                            <!--
                            <div class="mx-2 my-2 px-1 py-1 bg_grey text_azure">
                                <div class="mb-3 ms-1 me-1">
                                    <label for="fecha_publicacion" class="form-label">Fecha Publicación</label>
                                    <input type="text" class="form-control" id="fecha_publicacion"
                                        name="fecha_publicacion" placeholder="Ingresar fecha de publicación" 
                                        required>
                                </div>                                             
                            </div>
                            -->

                            <div class="mx-2 my-2 px-1 py-1 bg_grey text_azure">

                                <%- include ('input_categorias_form', { 
                                    url_categorias: "/blog/obtener_categorias_blog" }) %>

                                    <div id="id_div_categoria_null"></div>

                            </div>

                            <div class="bg_cyan mx-2 my-2 px-2 py-2">
                                <div class="d-grid d-md-flex justify-content-md-end">
                                    <button type="submit" class="btn btn-success me-2 px-1 py-1">Enviar datos
                                        Post</button>
                                </div>

                            </div>
                        </div>
                    </form>
                </div>

            </div>
        </section>
    </main>
    <footer class="bg_brown text_cyan">
        <div class="mx-2 my-2 px-2 py-2">
            <h4>Proyecto: Blog de SurCode25</h4>
            <h4>Autor: Salvador Mauricio Vilches Jerez</h4>
        </div>
    </footer>

    <script src="/scripts_js/bootstrap.bundle.js"></script>

    <script>


        function establecerDatosSession() {

            if (window.sessionStorage != null) {

                if (sessionStorage.getItem("datos_session_sc25")) {

                    const datos_session = JSON.parse(sessionStorage.getItem("datos_session_sc25"));
                    const nombreUsuario = datos_session.username;
                    const idUsuario = datos_session.id;

                    let string_cabecera = "<h5 class='text-end mx-3 my-1 px-1 py-1'>Sesión iniciada por: "
                        + nombreUsuario + "</h5>";

                    document.getElementById("div_datos_session").innerHTML = string_cabecera;

                    let string_input_autor = " <div class='mb-3 ms-1 me-1'>"
                        + "<label for='autor' class='form-label'>Autor del post</label>"
                        + "<input type='text' class='form-control' name='autor' value='"
                        + nombreUsuario + "' readonly></div>"
                        + " <div class='mb-3 ms-1 me-1'>"
                        + "<input type='text' class='form-control' name='id_autor' value='"
                        + idUsuario + "' readonly hidden></div>";
                    document.getElementById("div_input_autor").innerHTML = string_input_autor;
                } else {
                    let string_datos_session = "<h5 class='bg_yellow text_green text-center mx-1 my-1 py-2 border'>Sesión no iniciada, "
                        + "debe iniciar una sesión para enviar los datos.</h5>";
                    document.getElementById("div_datos_session").innerHTML = string_datos_session;
                }
            } else {
                //console.log("Navegador sin soporte para sessionStorage");
                let string_datos_session = "<h5>No se pudieron obtener los dats de sessión, "
                    + "Este navegador no tiene soporte para sessionStorage</h5>";
                document.getElementById("div_datos_session").innerHTML = string_datos_session;
            }
        }



