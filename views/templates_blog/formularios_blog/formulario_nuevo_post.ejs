        const formulario_post_prueba = document.getElementById("id_form_post_prueba");

        formulario_post_prueba.addEventListener("submit", function (event) {
            event.preventDefault();    // Evita el envío del formulario por defecto 

            const myFormData = new FormData(event.currentTarget);


            if (myFormData.get("categoria_nueva") || myFormData.get("id_categorias")) {

                fetch("/blog/agregar_post", {
                    method: "POST",
                    body: myFormData
                })
                    .then(response => response.json())
                    .then(data => {
                        console.log("Formulario enviado satisfactoriamente: ", data);

                        //window.location.assign("/blog/obtener_posteos");

                    })
                    .catch(error => {
                        console.error("Error: ", error);
                        //alert("Hubo un error al enviar formulario");
                    });

            } else {

                console.log("Debe ingresar al menos una categoría");

                let string_categorias_null = "<h4 class='bg_black text_red'>Debe ingresar al menos una categoría</h4>";

                getElementById("id_div_categoria_null").innerHTML = string_categorias_null;

            }

            //myFormData.append("rol_usuario", rolUsuario); 

            // Se puede detener la ejecución en cualquier lugar con: deburger
            // para mostrar lo que hay en formData: myFormData.get("clave"),  y nos muestra el valor.
            // para establecer un nuevo valor: myFormData.set("clave", "valor"); 



        }, false);


        function mostrarControlesImagen(post_con_imagen) {

            let stringSeleccionImagen = "";

            if (post_con_imagen) {

                stringSeleccionImagen = "<div class='mb-3 ms-1 me-1'>"
                    + "<label for='imagen_post' class='form-label'>URL de la imagen</label>"
                    + "<input type='file' class='form-control' name='imagen_post' required>"
                    + "</div>"
                    + "<div class='d-grid d-md-flex justify-content-md-end'>"
                    + "<span class='bg_green text_white me-2 px-2 py-1' style='cursor: pointer;'"
                    + " onclick='mostrarControlesImagen(false)'>"
                    + "Si no necesita agregar una imagen, presionar aquí</span></div>";

            } else {

                stringSeleccionImagen = "<div class='mb-3 ms-1 me-1'>"
                    + "<label for='imagen_url' class='form-label'>URL de la imagen</label>"
                    + "<input type='text' class='form-control' name='imagen_url' value='sin_imagen' readonly>"
                    + "</div>"
                    + "<div class='d-grid d-md-flex justify-content-md-end'>"
                    + "<span class='bg_green text_white me-2 px-2 py-1' style='cursor: pointer;'"
                    + " onclick='mostrarControlesImagen(true)'>"
                    + "Si necesita agregar una imagen, presionar aquí</span></div>";

            }

            document.getElementById("div_seleccion_imagen").innerHTML = stringSeleccionImagen;

        }

        window.addEventListener("load", establecerDatosSession, false);

