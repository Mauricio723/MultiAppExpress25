<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Formulario Update Post</title>

    
    <link rel="stylesheet" href="/estilos_css/bootstrap.min.css">
    <link rel="stylesheet" href="/estilos_css/estilos_main.css">
    <link rel="stylesheet" href="/estilos_css/colores_const.css">

</head>
<body>

     <header class="bg_blue text_white">
        <div class="mx-2 my-2 px-2 py-2">
            <h2>Blog SurCode25 - Formulario para actualizar post</h2>
        </div>
    </header>
    <main>

        <section>
            <div class="bg_beige mx-2 my-2 px-2 py-2">
                <h3 class="text-center">Formulario para actualizar  Posteos</h3>

                <h4>id para actualizar: <%= id_post %></h4>


                <div class="mx-2 my-2">

                    <!-- formulario para enviar con FormData -->
                    <form id="id_form_update_post" class="mx-2 my-2 px-2 py-2">
                        <div class="bg_midnightblue text_seashell mx-1 my-1 px-1 py-1">

                            <div class="mx-2 my-2 px-1 py-1 bg_grey text_azure">
                                <div class="mb-3 ms-1 me-1">
                                    <label for="titulo" class="form-label">Título del post</label>
                                    <input type="text" class="form-control" id="titulo" name="titulo"
                                        placeholder="Ingresar el título dle post" required mingthlenth="3"
                                        maxlength="50">
                                </div>
                            </div>

                            <div class="mx-2 my-2 px-1 py-1 bg_grey text_azure">
                                <div class="mb-3 ms-1 me-1">
                                    <label for="contenido" class="form-label">Contenido del post</label>
                                    <textarea class="form-control" id="contenido" rows="3" name="contenido" required
                                        minlength="10" maxlength="500">
                                    </textarea>
                                </div>
                            </div>

                            <div class="mx-2 my-2 px-1 py-1 bg_grey text_azure" id="div_seleccion_imagen">
                                <div class="mb-3 ms-1 me-1">
                                    <label for="imagen_url" class="form-label">URL de la imagen</label>
                                    <input type="text" class="form-control" name="imagen_url" value="sin_imagen"
                                        readonly>
                                </div>
                                <div class="d-grid d-md-flex justify-content-md-end">
                                    <span class="bg_green text_white me-2 px-2 py-1" style="cursor: pointer;"
                                        onclick="mostrarControlesImagen(true)">
                                        Si necesita agregar una imagen, presionar aquí
                                    </span>
                                </div>

                                <!--
                                <div class="mb-3 ms-1 me-1">
                                    <label for="imagen_post" class="form-label">URL de la imagen</label>                                    
                                    <input type="file" class="form-control" name="imagen_post" required>
                                </div>
                                -->
                            </div>

                            <div class="mx-2 my-2 px-1 py-1 bg_grey text_azure">
                                <div class="mb-3 ms-1 me-1">
                                    <label for="autor" class="form-label">Ingresar autor del post</label>
                                    <input type="text" class="form-control" id="autor" name="autor"
                                        placeholder="Autor del Post" required>
                                </div>
                            </div>

                            <!--
                            <div class="mx-2 my-2 px-1 py-1 bg_grey text_azure">
                                <div class="mb-3 ms-1 me-1">
                                    <label for="fecha_publicacion" class="form-label">Fecha Publicación</label>
                                    <input type="text" class="form-control" id="fecha_publicacion"
                                        name="fecha_publicacion" placeholder="Ingresar fecha de publicación" 
                                        required>
                                </div>                                             
                            </div>
                            -->

                            <div class="mx-2 my-2 px-1 py-1 bg_grey text_azure">
                                <div class="mb-3 ms-1 me-1">
                                    <label for="categoria" class="form-label">Categoría</label>
                                    <input type="text" class="form-control" id="categoria" name="categoria"
                                        placeholder="Ingresar categoría del post" required>
                                </div>
                            </div>

                            <div class="mx-2 my-2 px-2 py-2 border">
                                <button type="submit">Enviar datos Post</button>
                            </div>
                        </div>
                    </form>
                </div>

            </div>
        </section>
    </main>
    <footer class="bg_brown text_cyan">
        <div class="mx-2 my-2 px-2 py-2">
            <h4>Proyecto: Blog de SurCode25</h4>
            <h4>Autor: Salvador Mauricio Vilches Jerez</h4>
        </div>
    </footer>

    <script src="/scripts_js/bootstrap.bundle.js"></script>

    <script>

        const formulario_update_post = document.getElementById("id_form_update_post");

        formulario_update_post.addEventListener("submit", function (event) {
            event.preventDefault();    // Evita el envío del formulario por defecto 

            const myFormData = new FormData(event.currentTarget);

            //console.log("myFormData: ", myFormData.get("nueva_frace"));

            // Se puede detener la ejecución en cualquier lugar con: deburger
            // para mostrar lo que hay en formData: myFormData.get("clave"),  y nos muestra el valor.
            // para establecer un nuevo valor: myFormData.set("clave", "valor"); 

            fetch("/blog/actualizar_post", {
                method: "PATCH",
                body: myFormData
            })
                .then(response => response.json())
                .then(data => {
                    console.log("Formulario enviado satisfactoriamente: ", data);

                    // redireccionamos hacia la ruta que nos muestra todas las fraces
                    //window.location.assign("/blog/obtener_posteos");

                    // mostramos una ventana modal
                    //document.getElementById("customAlert").style.display = "block";

                    //document.getElementById("div_mensaje_retorno").innerHTML = "Mensaje: " + data.mensaje;

                })
                .catch(error => {
                    console.error("Error: ", error);
                    alert("Hubo un error al enviar formulario");
                });

        }, false);


        // Sección para controlar una ventana modal 
        /*
        document.getElementById('showAlert').addEventListener('click', function () {
            document.getElementById('customAlert').style.display = 'block';
        });
        */

        /*
        document.querySelector('.close-button').addEventListener('click', function () {
            document.getElementById('customAlert').style.display = 'none';
        });
        document.querySelector("#button_continuar").addEventListener("click", function () {
            //alert("Se presionó el botón para continuar");
            window.location.assign("/frases/obtener_frases");
        });
        */

        /*
        window.addEventListener('click', function (event) {
            if (event.target == document.getElementById('customAlert')) {
                document.getElementById('customAlert').style.display = 'none';
            }
        });
        */

        function mostrarControlesImagen(post_con_imagen) {

            let stringSeleccionImagen = "";

            if (post_con_imagen) {

                stringSeleccionImagen = "<div class='mb-3 ms-1 me-1'>"
                    + "<label for='imagen_post' class='form-label'>URL de la imagen</label>"
                    + "<input type='file' class='form-control' name='imagen_post' required>"
                    + "</div>"
                    + "<div class='d-grid d-md-flex justify-content-md-end'>"
                    + "<span class='bg_green text_white me-2 px-2 py-1' style='cursor: pointer;'"
                    + " onclick='mostrarControlesImagen(false)'>"
                    + "Si no necesita agregar una imagen, presionar aquí</span></div>";

            } else {

                stringSeleccionImagen = "<div class='mb-3 ms-1 me-1'>"
                    + "<label for='imagen_url' class='form-label'>URL de la imagen</label>"
                    + "<input type='text' class='form-control' name='imagen_url' value='sin_imagen' readonly>"
                    + "</div>"
                    + "<div class='d-grid d-md-flex justify-content-md-end'>"
                    + "<span class='bg_green text_white me-2 px-2 py-1' style='cursor: pointer;'"
                    + " onclick='mostrarControlesImagen(true)'>"
                    + "Si necesita agregar una imagen, presionar aquí</span></div>";

            }

            document.getElementById("div_seleccion_imagen").innerHTML = stringSeleccionImagen;

        }

    </script>

</body>
</html>