    <script>

        function obtenerPosteosDeUsuario(id_autor, usernameAutor) {
            //console.log("obteniendo posteos del usuario: ", id_autor);

            const string_url = "/blog/obtener_titulos_posteos_por_usuario/" + id_autor;

            fetch(string_url, {
                method: "GET",
                headers: {
                    "Content-Type": "application/json"
                }
            })
                .then(response => response.json())
                .then(datosRecibidos => {
                    console.log("datos obtenidos: ", datosRecibidos);

                    let string_titulos_posteos = "";

                    datosRecibidos.forEach(datos => {
                        string_titulos_posteos +=
                            "<p class='px-2 py-2'>"
                            + datos.id_post + " - "
                            + "<button onclick='obtenerPostSeleccionado(" + datos.id_post + ")'>"
                            + datos.titulo + "</button></p>";
                    });

                    let string_article_publicaciones = "<article class='bg_white mx-2 my-2 px-2 py-2'>"
                        + "<h4 class='mx-2 my-2 px-2 py-2'>Publicaciones de " + usernameAutor + "</h4>"
                        + string_titulos_posteos + "</article>";

                    document.getElementById("div_article_posteos").innerHTML = string_article_publicaciones;

                })
                .catch(error => {
                    console.error("error al obtener datos: ", error);
                });

        }

    </script>

