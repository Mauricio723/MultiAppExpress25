    <script>

        function iniciarScript03() {
            establecerAtosSesion();
        }

        function establecerDatosSesion() {
            // recuperamos los datos de session
            if (sessionStorage.getItem("datos_session_sc25") !== null) {
                const datos_session = JSON.parse(sessionStorage.getItem("datos_session_sc25"));
                //const id = datos_session.id;
                const username = datos_session.username;
                const rol = datos_session.rol;
                //const token = datos_session.token;
                const string_estado_session = "<div class='bg_black text_yellow'>"
                    + "<p class='text-end mx-3 my-1 px-2 py-1'><span>"
                    + "Sesión iniciada por: " + username + "</span><span class='mx-2'>rol: " + rol + "</span></p></div>";
                document.getElementById("div_estado_session_01").innerHTML = string_estado_session;

            } else {
                document.getElementById("div_estado_session_01").innerHTML = "<p>No se ha iniciado una sesión</p>";
            }

        }

        function eliminarDatosSession() {
            console.log("Elimninando datos de session");
            sessionStorage.removeItem("datos_session_sc25");
        }

        window.addEventListener("load", establecerDatosSesion, false);


    </script>

